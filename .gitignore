node_modules
.rex
.DS_Store
.env
.env.local
.env*.local
.env.build
/target
packages/server/dist/
# Embedded frontend assets — built from packages/app and copied in by
# packages/server/scripts/sync-frontend.sh (or build-pi.sh). Treat as build
# output: gitignored, populated at release-build time, but the dir tree
# (with .gitkeep) is checked in so rust-embed has something to look at.
packages/server/static/client/*
!packages/server/static/client/.gitkeep
packages/server/static/public/*
!packages/server/static/public/.gitkeep
packages/server/static/installer/*
!packages/server/static/installer/.gitkeep
packages/server/static/manifest.json
*.pem
.claude/settings.local.json
.claude/worktrees/
.claude/skills/
dist
packages/app/public/uploads/
packages/app/.cache/
packages/app/public/network-info.json
packages/app/.settings-overrides.json
CLAUDE.local.md
.wrangler
witness/output/*
!witness/output/.gitkeep
tests/integration/__harness__.json
witness-reports/

# SQLite runtime + WAL/SHM sidecars (per-machine dev/test artifacts).
# Both the app's `./pantry.db` and any *-snapshot.db files from
# PG→SQLite migration runs live here untracked.
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
