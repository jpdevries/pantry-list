# Copy to .env.build (gitignored). All values are optional.
#
# GHCR PAT: only needed if cross's pulls from ghcr.io return "denied" (rate
#           limit, corporate proxy, or you want authenticated pulls). The
#           token needs `read:packages` scope and is used by build-pi.sh to
#           `docker login ghcr.io` before invoking cross.

GHCR_USER=
GHCR_PAT=
