#!/bin/bash
# firstrun.sh — runs once on first boot, then removes itself.
#
# Generated by packages/image/build.sh from packages/image/.env.image.
# Placeholders ({NAME}) are filled in by customize.sh via a safe Python
# substitution before being copied to /boot/firmware/firstrun.sh.
#
# Pi OS Bookworm boots us through this script by way of a one-shot
# `systemd.run=/boot/firmware/firstrun.sh` appended to cmdline.txt. We clean
# up that cmdline entry at the end and trigger a reboot into the normal
# multi-user target.

set +e
exec > /var/log/firstrun.log 2>&1
echo "[firstrun] $(date -u +%FT%TZ) — beginning first-boot configuration"

# Hostname -------------------------------------------------------------------
NEW_HOST='{{HOSTNAME}}'
CURRENT_HOST="$(cat /etc/hostname || echo raspberrypi)"
echo "$NEW_HOST" > /etc/hostname
sed -i "s/127\.0\.1\.1.*$CURRENT_HOST/127.0.1.1\t$NEW_HOST/g" /etc/hosts
hostnamectl set-hostname "$NEW_HOST" || true

# User account ---------------------------------------------------------------
# Nothing to do here: the login user (password, group memberships, passwordless
# sudo, and SSH keys) is prebaked into the image offline by
# packages/image/customize.sh, which also disables the interactive first-boot
# user dialog (userconfig.service). Kept out of firstrun on purpose so there's
# a single source of truth for the account.

# SSH ------------------------------------------------------------------------
systemctl enable ssh.service
systemctl start ssh.service || true

# Timezone & keyboard --------------------------------------------------------
TIMEZONE='{{TIMEZONE}}'
if [ -n "$TIMEZONE" ]; then
  rm -f /etc/localtime
  echo "$TIMEZONE" > /etc/timezone
  dpkg-reconfigure -f noninteractive tzdata || true
fi
KB='{{KEYBOARD_LAYOUT}}'
if [ -n "$KB" ]; then
  sed -i "s/^XKBLAYOUT=.*/XKBLAYOUT=\"$KB\"/" /etc/default/keyboard || true
  dpkg-reconfigure -f noninteractive keyboard-configuration || true
fi

# WiFi via NetworkManager ----------------------------------------------------
# Bookworm Lite ships NetworkManager as the default networking stack. We
# drop a connection profile into /etc/NetworkManager/system-connections/
# with 0600 perms — that's the directory NM watches for static profiles.
WIFI_SSID='{{WIFI_SSID}}'
WIFI_PSK='{{WIFI_PSK}}'
WIFI_COUNTRY='{{WIFI_COUNTRY}}'
if [ -n "$WIFI_SSID" ]; then
  install -d -m 700 /etc/NetworkManager/system-connections
  cat > /etc/NetworkManager/system-connections/preconfigured.nmconnection <<NMCONN
[connection]
id=preconfigured
type=wifi
interface-name=wlan0
autoconnect=true

[wifi]
mode=infrastructure
ssid=$WIFI_SSID

[wifi-security]
key-mgmt=wpa-psk
psk=$WIFI_PSK

[ipv4]
method=auto

[ipv6]
method=auto
NMCONN
  chmod 600 /etc/NetworkManager/system-connections/preconfigured.nmconnection
fi
if [ -n "$WIFI_COUNTRY" ]; then
  # raspi-config writes the regulatory domain to /etc/default/crda + the
  # wireless-regdb. Falling back to `iw reg set` keeps it correct even on
  # Bookworm where /etc/default/crda has been deprecated.
  raspi-config nonint do_wifi_country "$WIFI_COUNTRY" || iw reg set "$WIFI_COUNTRY" || true
fi

# pantry-server --------------------------------------------------------------
# Service file + binary were placed by customize.sh; just enable + start.
systemctl daemon-reload
systemctl enable pantry-server.service
systemctl start pantry-server.service || true

# Tailscale ------------------------------------------------------------------
# Binary is pre-installed; the daemon is enabled in customize.sh. Auth
# happens later via the in-app installer flow (packages/installer-ui),
# which calls `tailscale up --operator=$USER` through the server's
# /api/tailscale/connect endpoint. Nothing to do here at first-run time.
systemctl enable tailscaled.service || true
systemctl start tailscaled.service || true

# Clean up: remove the firstrun directive from cmdline.txt so this script
# only ever runs once.
CMDLINE=/boot/firmware/cmdline.txt
if [ -f "$CMDLINE" ]; then
  sed -i 's| systemd\.run=/boot/firmware/firstrun\.sh||g; s| systemd\.run_success_action=reboot||g; s| systemd\.unit=kernel-command-line\.target||g' "$CMDLINE"
fi
rm -f /boot/firmware/firstrun.sh

echo "[firstrun] $(date -u +%FT%TZ) — done; rebooting into normal boot"
sync
exit 0
