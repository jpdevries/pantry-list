# packages/image/.env.image — copy to `.env.image` (gitignored) and fill in.
#
# Sourced by build.sh; customize.sh bakes these values straight into the
# image offline (hostname, NetworkManager WiFi profile, timezone, keyboard,
# user account). There's no first-boot script — the card boots once, already
# configured.

# --- Required ---------------------------------------------------------------

# WiFi network the Pi joins on first boot.
WIFI_SSID="your-network"
WIFI_PSK="your-password"

# Two-letter regulatory domain. Picks the right 2.4 GHz channels + tx power.
# (US, GB, DE, CA, AU, JP, …). The Pi Zero W is 2.4 GHz only.
WIFI_COUNTRY="US"

# --- Optional ---------------------------------------------------------------

# Hostname the Pi advertises (mDNS: <HOSTNAME>.local). Default: pantry.
HOSTNAME="pantry"

# Login user. The pantry-server systemd unit currently pins `pi`; if you
# change this, also edit packages/server/scripts/pantry-server.service and
# the TAILSCALE_OPERATOR env override on the unit.
USERNAME="pi"

# Plain-text password used to seed userconf.txt. Will be openssl-hashed at
# build time before being written to the boot partition. Leave empty for
# SSH-key-only access (requires SSH_AUTHORIZED_KEYS).
USER_PASSWORD="raspberry"

# Newline-separated SSH public keys to drop into ~/.ssh/authorized_keys.
# Multi-line values use $'\n' or a literal newline inside double quotes.
SSH_AUTHORIZED_KEYS=""

# Timezone (IANA name).
TIMEZONE="America/Los_Angeles"

# Keyboard layout passed to console-setup.
KEYBOARD_LAYOUT="us"

# --- Pi OS source ----------------------------------------------------------

# 32-bit Bookworm Lite is the last variant that supports the ARMv6 Pi Zero W.
# Pinning a specific dated build keeps `dd` artifacts reproducible; leave
# blank to follow the `_latest` redirector.
PI_OS_URL="https://downloads.raspberrypi.com/raspios_lite_armhf/images/raspios_lite_armhf-2025-05-13/2025-05-13-raspios-bookworm-armhf-lite.img.xz"
PI_OS_SHA256=""
